# ─── EnerLuma Backend Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values

# MongoDB connection string
# For local: mongodb://localhost:27017/enerluma
# For Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/enerluma
MONGO_URI=mongodb://localhost:27017/enerluma

# JWT secret key (change this to a random string in production!)
JWT_SECRET=enerluma-jwt-secret-change-me-in-production

# Frontend URL (used for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:5173

# ─── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=812276980622-3fniff33qmkge9u18tb5fnfbeujdaaoi.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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

# ─── Apple Sign-In ─────────────────────────────────────────────────────────────
# Get these from: https://developer.apple.com
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=
